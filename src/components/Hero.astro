---
---

<section class="hero">
  <div class="hero-left">
    <div class="hero-eyebrow">
      <div class="live-dot"></div>
      disponible para trabajar · Madrid, España
    </div>

    <h1 class="hero-h1">
      Carolina<br/>Rodríguez<br/>
      <span class="dim">Fullstack Developer.</span>
    </h1>

    <p class="hero-sub">
      Desarrollo aplicaciones web, móvil y sistemas que <strong>funcionan en producción.</strong><br/>
      Del frontend al backend, de la idea al despliegue.
    </p>

    <div class="hero-actions">
      <a href="#proyectos" class="btn btn-solid">Ver proyectos</a>
      <a href="#sobre-mi"  class="btn btn-ghost">Sobre mí</a>
      <a href="https://linkedin.com/in/carolinarodriguezbarcena" target="_blank" rel="noopener" class="btn btn-ghost">LinkedIn ↗</a>
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-code">
<span class="code-key">const</span> carol = &#123;<br/>
&nbsp;&nbsp;rol:&nbsp;&nbsp;&nbsp;<span class="code-str">"Fullstack Dev"</span>,<br/>
&nbsp;&nbsp;studio:&nbsp;<span class="code-str">"Stibios"</span>,<br/>
&nbsp;&nbsp;años:&nbsp;&nbsp;<span class="code-str">"+4 prod"</span>,<br/>
&nbsp;&nbsp;stack:&nbsp;&nbsp;<span class="code-str">"React · Python · AI"</span>,<br/>
&nbsp;&nbsp;AI:&nbsp;&nbsp;&nbsp;&nbsp;<span class="code-bool">true</span>,<br/>
&nbsp;&nbsp;open:&nbsp;&nbsp;<span class="code-bool">true</span>,<br/>
&#125;;
    </div>
  </div>

  <div class="hero-meta">
    <div class="meta-item">STATUS&nbsp;&nbsp;<span>OPEN</span></div>
    <div class="meta-item">EXP&nbsp;&nbsp;<span>+4 años</span></div>
    <div class="meta-item">STUDIO&nbsp;&nbsp;<span>Stibios</span></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    column-gap: 4rem;
    padding: 0 5vw;
    padding-top: 56px;
    position: relative;
  }

  .hero-left  { display: flex; flex-direction: column; justify-content: center; }
  .hero-right { display: flex; align-items: center; justify-content: flex-end; }

  .hero-code {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 1.5rem 1.75rem;
    font-family: 'JetBrains Mono', monospace; font-size: .72rem;
    line-height: 2; color: var(--muted2);
    white-space: nowrap;
    opacity: 0; animation: up .7s 1.1s forwards;
  }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: .6rem;
    font-family: 'JetBrains Mono', monospace; font-size: .72rem;
    color: var(--muted2); letter-spacing: .08em; margin-bottom: 2.5rem;
    opacity: 0; animation: up .6s .2s forwards;
  }
  .live-dot {
    width: 6px; height: 6px; background: var(--green); border-radius: 50%;
    animation: livepulse 2s infinite;
  }

  .hero-h1 {
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 600; line-height: 1.0; letter-spacing: -.03em;
    color: var(--white); margin-bottom: 1.75rem;
    opacity: 0; animation: up .7s .35s forwards;
  }
  .hero-h1 .dim { color: var(--muted); font-weight: 300; }

  .hero-sub {
    font-size: 1.05rem; line-height: 1.75; color: var(--muted2);
    max-width: 560px; margin-bottom: 2.5rem;
    opacity: 0; animation: up .7s .5s forwards;
  }
  .hero-sub strong { color: var(--text); font-weight: 500; }

  .hero-actions {
    display: flex; gap: .75rem; flex-wrap: wrap;
    opacity: 0; animation: up .6s .65s forwards;
  }

  .btn {
    display: inline-flex; align-items: center; gap: .4rem;
    font-size: .8rem; font-weight: 500; text-decoration: none;
    border-radius: 8px; padding: .6rem 1.25rem; transition: all .2s; cursor: none;
  }
  .btn-solid { background: var(--accent); color: var(--white); }
  .btn-solid:hover { background: #8f84f9; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(124,110,247,.3); }
  .btn-ghost { background: transparent; color: var(--muted2); border: 1px solid var(--border2); }
  .btn-ghost:hover { color: var(--white); background: var(--bg2); }

  .hero-meta {
    position: absolute; bottom: 2.5rem; left: 5vw;
    display: flex; align-items: center; gap: 2rem;
    opacity: 0; animation: up .5s .9s forwards; grid-column: 1 / -1;
  }
  .meta-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem; color: var(--muted); letter-spacing: .08em;
  }
  .meta-item span { color: var(--muted2); }

  .code-key  { color: var(--accent); }
  .code-str  { color: #f9a870; }
  .code-bool { color: var(--green); }

  @media(max-width: 900px) {
    .hero { grid-template-columns: 1fr; padding: 0 1.25rem; padding-top: 56px; }
    .hero-right { display: none; }
    .hero-meta  { left: 1.25rem; }
  }
</style>
